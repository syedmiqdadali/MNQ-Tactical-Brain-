# ─── LiveKit Cloud ────────────────────────────────────────────────────────────
# Create a project at https://cloud.livekit.io and copy these from Settings → Keys.
# All three are required; the agent fails fast on boot if any are missing.
LIVEKIT_URL=wss://your-project-XXXXXXXX.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=long-random-secret-from-livekit-cloud
LIVEKIT_ROOM_NAME=jarvis-room
# Identity used by the agent participant. Browsers use a different identity (e.g. dispatcher-<userId>).
LIVEKIT_AGENT_IDENTITY=jarvis-agent

# ─── Ollama (LLM) ─────────────────────────────────────────────────────────────
# OpenAI-compatible endpoint at /v1/chat/completions. On RunPod the agent talks
# to Ollama on localhost (same pod). Local-dev compose used to run a separate
# container; prefer RunPod for any real testing.
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M

# ─── Kokoro-fastapi (TTS) ─────────────────────────────────────────────────────
# OpenAI-compatible /v1/audio/speech. Same-pod localhost on RunPod.
# Stock voices: bm_lewis (British male, recommended), bf_emma (British female),
# am_michael, af_bella. Full list: kokoro-fastapi /v1/audio/voices endpoint.
KOKORO_BASE_URL=http://127.0.0.1:8880/v1
KOKORO_VOICE=bm_lewis

# ─── Whisper (STT) ────────────────────────────────────────────────────────────
# Models: tiny / base / small / medium / large-v3 (multilingual, best quality).
# Use `medium` for sub-second English STT; `large-v3` if Urdu must be excellent.
WHISPER_MODEL=medium
WHISPER_DEVICE=cuda
# float16 on GPU, int8 on CPU (CPU is for plumbing checks only)
WHISPER_COMPUTE_TYPE=float16
# Two-letter ISO code or "auto" (auto adds ~50 ms language detection per utterance)
WHISPER_LANGUAGE=en

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
